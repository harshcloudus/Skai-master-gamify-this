# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Webhook / agent endpoint security
# For custom tool endpoints (menu match, check-takeaway, personalize):
# set this to a random secret and add it as X-Webhook-Secret header in
# ElevenLabs tool config. Leave empty to skip in dev.
WEBHOOK_SECRET=
# For the ElevenLabs post-call webhook (HMAC auth):
# paste the secret ElevenLabs generates when you enable HMAC on the webhook.
# Leave empty to skip signature verification in dev.
ELEVENLABS_WEBHOOK_SECRET=
# Set to false to skip Twilio signature validation in local dev
TWILIO_VALIDATE_SIGNATURES=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
ENV=development
